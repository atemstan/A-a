#include <stdio.h>

int cocanh(int u,int v, char graph[][5]){
	int count=0;
	for(int j=0;j<5;j++){
			if(graph[u][j]==graph[v][j]){
				count++;
			}
		}	
	if(count==4){
		return 1;
	}else{
		return 0;
	}
}
void explore(int u, int visited[], char graph[][5]){
	int u1;
	visited[u] = 1;

    for(int i=0;i<5757;i++){
    	if( cocanh(u,i,graph)&&!visited[i])
        {
            explore(i,visited,graph);
        }
    }
      
 
}

